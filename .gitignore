# Python bytecode caches
__pycache__/
*.py[cod]
*$py.class

# Scratch / diagnostic convention: root-level files prefixed with "_" are
# throwaway (one-off diagnostics, run logs, pickled checkpoints). Kept local,
# never shared. Real modules / tests / docs never start with "_".
/_*
tests/_*

# cProfile dumps (we generate these during performance work)
*.prof

# LaTeX build artifacts (from compiling GR Bootstrapping for Venusians.tex)
*.aux
*.log
*.out
*.bbl
*.blg
*.toc
*.synctex.gz
*.fdb_latexmk
*.fls
*.pdf

# Per-user Claude Code settings (local-only by convention)
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Paper source and the GR.fr Mathematica notebook — kept locally but not
# part of the shared repo (the code is what's being shared).
GR Bootstrapping for Venusians.tex
GR.fr

# OS / editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~
